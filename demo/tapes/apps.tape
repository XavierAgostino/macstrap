# macstrap app-picker demo — regenerate with:  vhs demo/tapes/apps.tape
# Drives demo/scripts/02-app-picker.sh (scripted, non-mutating).

Output .github/assets/demo-apps.gif

Set Shell "bash"
Set FontSize 18
Set Width 1200
Set Height 620
Set Padding 24
Set Theme "Catppuccin Mocha"

Hide
Type "export PATH=$PWD/bin:$PATH" Enter
Ctrl+L
Show

Type "macstrap demo apps" Enter
Sleep 7s
