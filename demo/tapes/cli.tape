# macstrap cli-picker demo — regenerate with:  vhs demo/tapes/cli.tape
# Drives demo/scripts/03-cli-picker.sh (scripted, non-mutating).

Output .github/assets/demo-cli.gif

Set Shell "bash"
Set FontSize 18
Set Width 1200
Set Height 700
Set Padding 24
Set Theme "Catppuccin Mocha"

Hide
Type "export PATH=$PWD/bin:$PATH" Enter
Ctrl+L
Show

Type "macstrap demo cli" Enter
Sleep 8s
