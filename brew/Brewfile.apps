# Brewfile.apps — modern-standard GUI apps, installed out of the box.
# A focused, professional set most engineers reach for. TRIM what you don't want.
# Install:  brew bundle --file=brew/Brewfile.apps   (or skip with APPS=0)

# --- Editors & AI ---
cask "cursor"                         # AI-native editor
cask "visual-studio-code"
cask "claude-code"                    # terminal AI coding agent

# --- Browser ---
cask "google-chrome"

# --- Launcher & window management (big quality-of-life) ---
cask "raycast"                        # launcher / clipboard / window mgmt / scripts
cask "rectangle"                      # keyboard window snapping

# --- Dev: containers & databases ---
cask "orbstack"                       # fast Docker/Linux VMs (lighter than Docker Desktop)
cask "tableplus"                      # database GUI

# --- Knowledge & docs ---
cask "obsidian"                       # markdown knowledge base
cask "notion"

# --- Design ---
cask "figma"

# --- Communication ---
cask "slack"
cask "zoom"

# --- Media ---
cask "spotify"

# --- Editor extensions (installed via the `code` CLI; best-effort) ---
vscode "dbaeumer.vscode-eslint"
vscode "esbenp.prettier-vscode"
vscode "bradlc.vscode-tailwindcss"
vscode "eamodio.gitlens"
vscode "ms-python.python"
vscode "ms-azuretools.vscode-docker"
vscode "pkief.material-icon-theme"
vscode "raunofreiberg.vesper"

