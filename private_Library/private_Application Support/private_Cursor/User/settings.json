{
    "editor.fontFamily": "Geist Mono",
    "editor.fontLigatures": true,
    "editor.fontSize": 13,
    "terminal.integrated.fontFamily": "Geist Mono",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontLigatures": true,
    "terminal.integrated.sendKeybindingsToShell": true,
    "terminal.external.osxExec": "Ghostty.app",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "Vesper",
    "window.autoDetectColorScheme": false,
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.python"
    },
    "workbench.colorCustomizations": {
        "[Vesper]": {
            "editor.background": "#1c1c1c",
            "editor.foreground": "#ffffff",
            "editorGroupHeader.tabsBackground": "#1a1a1a",
            "sideBar.background": "#1a1a1a",
            "sideBarSectionHeader.background": "#1a1a1a",
            "activityBar.background": "#1a1a1a",
            "titleBar.activeBackground": "#1a1a1a",
            "titleBar.inactiveBackground": "#181818",
            "statusBar.background": "#1a1a1a",
            "panel.background": "#1c1c1c",
            "tab.activeBackground": "#242424",
            "tab.inactiveBackground": "#181818",
            "tab.border": "#1a1a1a",
            "terminal.background": "#1a1a1a",
            "terminal.foreground": "#ffffff",
            "terminal.ansiBlack": "#101010",
            "terminal.ansiBrightBlack": "#8a8a8a",
            "terminal.ansiRed": "#f4777f",
            "terminal.ansiBrightRed": "#f4777f",
            "terminal.ansiGreen": "#8fb59c",
            "terminal.ansiBrightGreen": "#8fb59c",
            "terminal.ansiYellow": "#e0b18f",
            "terminal.ansiBrightYellow": "#e0b18f",
            "terminal.ansiBlue": "#a8a0cc",
            "terminal.ansiBrightBlue": "#a8a0cc",
            "terminal.ansiMagenta": "#d996c8",
            "terminal.ansiBrightMagenta": "#d996c8",
            "terminal.ansiCyan": "#8f89aa",
            "terminal.ansiBrightCyan": "#8f89aa",
            "terminal.ansiWhite": "#ffffff",
            "terminal.ansiBrightWhite": "#ffffff",
            "editorGutter.addedBackground": "#8fb59c",
            "editorGutter.deletedBackground": "#f4777f",
            "editorGutter.modifiedBackground": "#a8a0cc",
            "gitDecoration.addedResourceForeground": "#8fb59c",
            "gitDecoration.modifiedResourceForeground": "#a8a0cc",
            "gitDecoration.deletedResourceForeground": "#f4777f"
        }
    },
    "editor.tokenColorCustomizations": {
        "[Vesper]": {
            "comments": "#8a8a8a",
            "strings": "#8fb59c",
            "keywords": "#d996c8",
            "functions": "#a8a0cc",
            "numbers": "#e0b18f",
            "types": "#a8a0cc"
        }
    }
}
