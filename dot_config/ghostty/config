# Ghostty config. Soft, minimal Vesper aesthetic.
# Readable by default; opt into translucency/blur via the "aesthetic mode" block.

window-padding-color = background
theme = Vesper

font-family = "Geist Mono"
font-size = 13
font-feature = calt
font-feature = liga

window-padding-x = 8
window-padding-y = 6

cursor-style = block
cursor-style-blink = false

# Readable default: opaque, no blur (keeps text high-contrast on any wallpaper).
background-opacity = 0.98
background-blur-radius = 0

# Aesthetic mode: soft translucency + blur. Uncomment to enable.
# background-opacity = 0.94
# background-blur-radius = 6

macos-titlebar-style = tabs

mouse-hide-while-typing = true
mouse-scroll-multiplier = 1.0
shell-integration = zsh
confirm-close-surface = true

clipboard-read = ask
clipboard-write = allow

term = xterm-256color
